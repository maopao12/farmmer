{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": { "navigationBarTitleText": "实时监测" }
    },
    {
      "path": "pages/control/control",
      "style": { "navigationBarTitleText": "设备控制" }
    },
    {
      "path": "pages/ai/ai",
      "style": { "navigationBarTitleText": "AI农事助手" }
    },
    {
      "path": "pages/mine/mine",
      "style": { "navigationBarTitleText": "我的" }
    },
    {
      "path": "pages/login/login",
      "style": { "navigationBarTitleText": "登录" }
    }
  ],
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#1a73e8",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "监测",
        "iconPath": "static/icons/monitor.png",
        "selectedIconPath": "static/icons/monitor-active.png"
      },
      {
        "pagePath": "pages/control/control",
        "text": "控制",
        "iconPath": "static/icons/control.png",
        "selectedIconPath": "static/icons/control-active.png"
      },
      {
        "pagePath": "pages/ai/ai",
        "text": "AI助手",
        "iconPath": "static/icons/ai.png",
        "selectedIconPath": "static/icons/ai-active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "static/icons/mine.png",
        "selectedIconPath": "static/icons/mine-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "智慧农业",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f8f9fa"
  }
}
